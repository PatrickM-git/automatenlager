# =============================================================================
# Verbindungsdaten für Tools/Claude — Vorlage.
# Kopiere diese Datei zu  dashboard/.env.connections  und trage die ECHTEN
# Werte ein. Die echte Datei ist per .gitignore ausgeschlossen (nie committen).
# Secrets niemals in den Chat schreiben — nur in diese Datei.
# =============================================================================

# --- n8n PRODUKTION: IMMER der HP Mini (24/7), NIE die lokale Instanz ---------
# Regel: Alle Workflow-Änderungen (WF0–WF9) laufen ausschließlich gegen den Mini.
# localhost:5678 ist die lokale Dev-Instanz mit veralteten/inaktiven Kopien und
# ABWEICHENDEN Workflow-IDs — dort zu arbeiten ist wirkungslos.
N8N_MINI_BASE_URL=https://hp-mini-server.tail573a13.ts.net
# API-Key der MINI-n8n (verifiziert, HTTP 200 gegen Mini):
#   liegt als  N8N_API_KEY  in  C:\Users\patri\Documents\homelab\.env.local
# ACHTUNG: NICHT verwenden (= LOKALE Instanz, Mini -> HTTP 401):
#   - C:\Users\patri\.n8n-api-key
#   - ELITEBOOK_N8N_API_KEY (homelab/.env.local)
N8N_MINI_API_KEY=

# Bekannte produktive Workflow-IDs auf dem Mini (zur Verifikation vor Änderungen):
#   WF1 (Rechnungseingang) = wnGAwHhgfXq2ATM8
N8N_MINI_WF1_ID=wnGAwHhgfXq2ATM8

# --- Nayax API ---------------------------------------------------------------
# Für den Abgleich von Verkaufs-/Telemetrie-Daten (z. B. unzugeordnete Verkäufe).
NAYAX_API_BASE_URL=
NAYAX_API_KEY=
NAYAX_ACTOR_ID=
NAYAX_MARKETPLACE_ID=
