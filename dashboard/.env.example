N8N_BASE_URL=http://127.0.0.1:5678
N8N_API_KEY=deinen_n8n_api_key_hier_einfuegen
DASHBOARD_ADMIN_LOGIN=patrick@example.com
# Partner: alles sehen (betrieb.lesen + finanzen.lesen), nichts schreiben.
# Komma-getrennt für mehrere Kollegen.
# DASHBOARD_PARTNER_LOGIN=kollege@example.com
# Audit-Trail (#32/#213): MASSGEBLICHE Senke ist die DB-Tabelle audit.access_log
# (Migration 0035, überlebt Container-Restarts); die JSONL-Datei unten ist nur noch
# best-effort-Fallback für lokale Dev. DASHBOARD_AUDIT_DB=off|on übersteuert die
# DB-Senke explizit; Default: an (unter dem node:test-Runner automatisch aus, damit
# Test-Läufe die echte Telemetrie nicht fluten und keine falschen AUTH_FAIL_SPIKEs
# [#168] provozieren).
# DASHBOARD_AUDIT_DB=on
DASHBOARD_AUDIT_LOG=dashboard/logs/guest-access.jsonl
# n8n-Legacy-Laufzeit-Config (POST /api/config). Env-Variablen (N8N_*) haben IMMER
# Vorrang; das Datei-Schreiben ist best-effort (#213, flüchtiges Cloud-FS). Pfad
# optional relozierbar:
# DASHBOARD_CONFIG_FILE=dashboard/.dashboard-config.json
# Optional: Rechnungs-Upload direkt an einen festen n8n-Webhook posten (z. B. Mini-n8n),
# unabhaengig von N8N_BASE_URL. Der Webhook legt die Datei im Drive-Ordner Rechnungseingang ab.
# INVOICE_UPLOAD_WEBHOOK_URL=https://hp-mini-server.tail573a13.ts.net/webhook/wf1-rechnung-upload
# Vollabgleich Slotbelegung + Fuellstand aus Nayax: Webhook des Mini-WF "Nayax-Abgleich".
# mode=preview liefert die Nayax-machineProducts (read-only), mode=apply schreibt ueber WF-PGW.
# Pflicht fuer den "Aus Nayax abgleichen"-Knopf im v3-Dashboard (/slots).
# NAYAX_ABGLEICH_WEBHOOK_URL=http://n8n:5678/webhook/nayax-abgleich

# ─────────────────────────────────────────────────────────────────────────────
# Stufe 6 — Worker-Dienst (n8n-Ablösung). Diese Werte gehören in .env.local
# (NIEMALS ins Git). Der Worker (dashboard/worker.js) liest sie beim Start.
# ─────────────────────────────────────────────────────────────────────────────
# DB: App-Verbindung (Rolle automatenlager_app, RLS) für die Jobs durch die Tür;
# Infra-Verbindung (BYPASSRLS) für Registry/MatView/Telemetrie. Format wie server.js.
# DASHBOARD_V2_PG_URL=<App-PG-Verbindung, RLS>
# DASHBOARD_V2_APP_PG_URL=<optional separat; sonst = DASHBOARD_V2_PG_URL>

# E-Mail (Mailer-Modul, Resend — seit Slice 1 live). Für WF5-Digest + WF-Val/Monitor/Proposals.
# RESEND_API_KEY=<resend-key>
# MAIL_FROM=onboarding@resend.dev
# ALERT_EMAIL_DEFAULT=betreiber@example.com

# Anthropic (Slice 2): WF-Claude-Proposals (Vorentscheidung) + WF9 Pickliste-OCR.
# Modelle hartkodiert (claude-haiku-4-5-20251001). Ohne Key laufen die Jobs, rufen
# Claude aber NICHT ("Anthropic: disabled" im Worker-Log).
# ANTHROPIC_API_KEY=<anthropic-key>

# WF9 Pickliste (Slice 2): Google-Drive-Client (PDF-Ordner) ist eine OAuth-Abhängigkeit;
# ohne Client ist der WF9-Worker-Job "disabled". Beim Bau des Drive-Clients hier den
# Ziel-Mandanten setzen (Drive-Ordner → Mandant). Deploy-spezifisch.
# WF9_TENANT_ID=t_faltrix            # oder NAYAX_TENANT_ID
# GOOGLE_DRIVE_CLIENT_ID=<oauth-client-id>
# GOOGLE_DRIVE_CLIENT_SECRET=<oauth-client-secret>
# GOOGLE_DRIVE_REFRESH_TOKEN=<oauth-refresh-token>   # aus der n8n googleDriveOAuth2Api-Credential
# GOOGLE_DRIVE_PICKLIST_FOLDER_ID=1Djrp-44NtazCB3pa-07S-uK769gJ2ZcS   # Quell-Ordner (Picklisten)
# GOOGLE_DRIVE_PROCESSED_FOLDER_ID=1mOMTE-vTAKFqOO5DW_q9UQ1Hgd7MHV38  # Ziel nach Verarbeitung

# WF1 Rechnungseingang (n8n-Ablösung 2026-06-11): EIGENES Drive-Ordnerpaar — der
# Dashboard-Upload legt PDFs direkt in den Rechnungseingang-Ordner, der Worker-Job
# wf1-invoice-intake pollt ihn (gleiche OAuth-Credential wie WF9). WF1_TENANT_ID
# ist Pflicht für den Intake (sonst skipped). INVOICE_UPLOAD_WEBHOOK_URL (n8n) ist
# nur noch Fallback, wenn die Invoice-Ordner NICHT gesetzt sind.
# WF1_TENANT_ID=t_faltrix
# GOOGLE_DRIVE_INVOICE_FOLDER_ID=<drive-ordner Rechnungseingang>
# GOOGLE_DRIVE_INVOICE_PROCESSED_FOLDER_ID=<drive-ordner verarbeitet>

# Nayax-Vollabgleich (/slots-Knopf, n8n-Ablösung 2026-06-11): läuft jetzt DIREKT
# gegen die Nayax-API (NAYAX_API_TOKEN/NAYAX_BASE_URL/NAYAX_HEADER_NAME, s. o.) —
# NAYAX_ABGLEICH_WEBHOOK_URL ist obsolet. Ebenso SLOT_CHANGE_WEBHOOK_URL (der
# Produktwechsel bucht direkt durch die Mandanten-Tür).

# Schedule-Overrides (sonst Defaults): WF-Claude-Proposals 04:30, WF5 07:00, WF9 alle 5 min.
# WORKER_PROPOSALS_AT=04:30
# WORKER_WF5_AT=07:00
# WORKER_WF9_MS=300000

# Slice 3 (#163): WF3 Nayax-Verkäufe + WF1 Rechnungseingang. DEFAULT Schattenbetrieb
# (rechnen + vergleichen, KEIN Schreiben). Cutover erst nach bewiesener Deckungsgleichheit:
# WF3_CUTOVER=1 / WF1_CUTOVER=1 (dann durch die Tür schreiben). NAYAX_TENANT_ID = Ziel-Mandant.
# WF3_CUTOVER=1
# WF1_CUTOVER=1
# WF3 Nayax-Verkaufs-Import: Intervall in ms (Default 300000 = alle 5 Min, wie der
# n8n-Schedule-Trigger). Treibt die Live-Umsatz-Kachel + tagesaktuelle sales_transactions.
# WORKER_WF3_MS=300000
# WORKER_WF1_MS=600000

# Live-Füllstand-Sync (#222): schreibt slot_assignments.current_machine_qty alle
# 5 Min aus Nayax fort — NUR Mengen (qty_changes, direktes UPDATE der aktiven
# Zuordnung), NIEMALS Slot-Umbelegungen (assignment_changes bleiben beim
# manuellen Abgleich mit Admin-Freigabe). Intervall in ms (Default 300000 = 5 Min).
# WORKER_NAYAX_FILL_MS=300000

# Nachbuch-Reconciliation (#221): holt unvollständig gelieferte Verkäufe (gross=0:
# fehlender Preis / nicht abgebucht) erneut von Nayax (lastSales) und bucht FIFO nach,
# sobald Preis UND Bestand verfügbar sind — idempotent (gross<=0-Guard), auditiert in
# audit.sales_reconciliation_log. KONSERVATIV: läuft NUR, wenn dieses Intervall gesetzt
# ist (Korrektur-Job, der bestehende Zeilen verändert). Arbeitsvorrat sichtbar unter
# GET /api/v2/reconcile/backlog. Intervall in ms (z. B. 3600000 = stündlich).
# WORKER_RECONCILE_MS=3600000

# Cutover-Readiness-Wächter (#198, täglich 02:00): zählt deckungsgleiche Schattenläufe,
# mailt bei Erreichen der Schwelle UND eröffnet bei einem Diff ein GitHub-Issue (24/7),
# damit der Fix im Backlog auftaucht. Ohne GITHUB_TOKEN/REPO ist nur die Mail aktiv.
# CUTOVER_STREAK_THRESHOLD=7
# WORKER_CUTOVER_AT=02:00
# GITHUB_TOKEN=<token mit issues:write>
# GITHUB_REPO=PatrickM-git/automatenlager

# Sicherheits-/Anomalie-Monitor (#168, alle 30 min): Auth-Fail-Häufung (guest-access.jsonl),
# Break-Glass-Nutzung, error-Run-Spike (audit.workflow_runs), Backup-Fehler (warnings).
# Mailt an ALERT_EMAIL_DEFAULT. Schwellwerte/Fenster überschreibbar.
# WORKER_ANOMALY_MS=1800000
# ANOMALY_WINDOW_MIN=60
# ANOMALY_AUTHFAIL_MAX=10
# ANOMALY_ERRORRUN_MAX=5

# Harter Timeout für ALLE externen HTTP-Calls (lib/fetch-timeout.js, Audit 2026-06-10):
# Default 30 s (Claude 120 s). Override gilt prozessweit für alle Clients.
# EXTERNAL_FETCH_TIMEOUT_MS=30000

# ── Cloud-Migration Phase B (Slice 1, #214): Supabase-DB ─────────────────────
# Supabase-Projekt "Faltrix" (eu-central-1). Drei Verbindungen (Werte in .env.local):
#  - SESSION (Port 5432, Supavisor Session-Mode): Infra — Bootstrap/Migrationen/
#    MatView-Refresh/Isolationssuite. Verbindet als postgres (RLS-Bypass).
#  - TX (Port 6543, Transaction-Mode, User postgres): nur Ad-hoc-Infra.
#  - APP TX (Port 6543, User automatenlager_app.<projekt-ref>): App-Pool OHNE
#    RLS-Umgehung — wird beim Cutover zu DASHBOARD_V2_APP_PG_URL.
# Die Isolationssuite läuft gegen Supabase via:
#   DASHBOARD_V2_PG_URL=$SUPABASE_PG_URL_SESSION node --test tests/dashboard-mt-*.test.js
# SUPABASE_DB_PASSWORD=<postgres-Passwort, Passwortmanager>
# SUPABASE_PG_URL_SESSION=postgresql://postgres.<ref>:<pw>@aws-1-eu-central-1.pooler.supabase.com:5432/postgres
# SUPABASE_PG_URL_TX=postgresql://postgres.<ref>:<pw>@aws-1-eu-central-1.pooler.supabase.com:6543/postgres
# SUPABASE_APP_PG_URL_TX=postgresql://automatenlager_app.<ref>:<app-pw>@aws-1-eu-central-1.pooler.supabase.com:6543/postgres

# ── Cloud-Migration Phase B (Slice 2, #215): Auth-Naht (Doppelpfad) ──────────
# DASHBOARD_AUTH_MODE steuert die Identitätsquelle (kein Code-Stichtag):
#  - (leer)/tailscale  → wie bisher: Tailscale-Header (Mini-Betrieb)
#  - supabase          → Identität NUR aus dem verifizierten Supabase-JWT
#    (Signaturprüfung gegen {SUPABASE_URL}/auth/v1/.well-known/jwks.json, ES256);
#    der Tailscale-Header wird dann NIE verwendet (aus dem Internet spoofbar).
#    Mapping E-Mail → tenantId/roleKey läuft unverändert über tenant_users +
#    DASHBOARD_ADMIN_LOGIN/PARTNER/OPERATOR-Allowlisten.
# SUPABASE_ANON_KEY ist der ÖFFENTLICHE Browser-Key (Login-Frontend via
# /api/v2/auth/config) — kein Secret; das Service-Role-Pendant bleibt geheim.
# DASHBOARD_AUTH_MODE=supabase
# SUPABASE_URL=https://<projekt-ref>.supabase.co
# SUPABASE_ANON_KEY=<public anon key aus Supabase Settings → API>
# SUPABASE_JWKS_URL=<nur für Tests/Sonderfälle; Default ist von SUPABASE_URL abgeleitet>

# ── Cloud-Migration / Betriebsreife (#216): Off-Site-Backup der Supabase-DB ──
# Geplanter pg_dump (custom-Format, Schemas automatenlager+audit) an einen
# Off-Site-Ort + Alarm: Fehlerlauf schreibt eine BACKUP_FAIL-Warnung (Anomalie-
# Monitor mailt kritisch) + direkte Alarm-Mail; ausbleibender Lauf (> MAX_AGE_H)
# wird vom Anomalie-Monitor als BACKUP_STALE gemailt. Erfolg löst FAIL auf.
# WICHTIG: Supabase ist PG 17 ⇒ SUPABASE_BACKUP_PG_BIN muss auf PG-17-Clients
# zeigen (pg_dump/pg_restore), sonst „server version mismatch".
# SUPABASE_BACKUP_DIR=D:\backups\supabase            # Off-Site-Ziel (Mini: externe Platte)
# SUPABASE_BACKUP_PG_BIN=C:\Program Files\PostgreSQL\17\bin
# SUPABASE_BACKUP_RETENTION_DAYS=30
# SUPABASE_BACKUP_MIN_BYTES=20000
# SUPABASE_BACKUP_MAX_AGE_H=30
# WORKER_BACKUP_AT=03:15

# ── Cloud-Migration (Slice 3, #217): Render-Backend + Cron-Trigger + Sentry ──
# WORKER_TRIGGER_SECRET schützt die Job-Trigger-Endpunkte POST /internal/jobs/<key>
# (Supabase pg_cron→pg_net ruft sie auf). OHNE diesen Wert ist der Pfad tot (404).
# Auf Render via generateValue automatisch erzeugt; derselbe Wert in pgcron-setup.sql.
# WORKER_TRIGGER_SECRET=<starkes Zufalls-Secret>
# SENTRY_DSN=https://<key>@<org>.ingest.de.sentry.io/<project>   # leer = Error-Tracking aus
# SENTRY_ENVIRONMENT=render

# ── Cloud-Migration (Slice 4, #218): Frontend auf Cloudflare, CORS ──────────
# DASHBOARD_CORS_ORIGINS: erlaubte Frontend-Origins (Cloudflare), komma-getrennt.
# Leer (Mini) ⇒ CORS inert (same-origin). Keine Cookie-Credentials (Bearer-JWT).
# DASHBOARD_CORS_ORIGINS=https://app.faltrix-solutions.de,https://faltrix.pages.dev
# Frontend-API-Basis kommt NICHT aus Env, sondern aus public/config.js
# (window.__API_BASE__) — auf Cloudflare via deploy/cloudflare/config.cloud.js.

# ── Etappe 3 (Audit H2/M1): Origin-Schutz + Rate-Limiting ────────────────────
# CF_ORIGIN_SECRET: geheimer Header, den Cloudflare (Pages-Function) auf jedem
# API-Request setzt. Gesetzt ⇒ das Backend akzeptiert nur Requests mit diesem
# Header (Direktzugriff auf *.onrender.com ⇒ 403, Cloudflare-Bypass dicht).
# LEER ⇒ Schutz INERT (Mini/vor-Cloudflare; kein Selbst-Aussperren). Derselbe
# Wert muss in der Render-Env UND in den Cloudflare-Pages-Env stehen.
# CF_ORIGIN_SECRET=<starkes Zufalls-Secret>
# Rate-Limit (Flooding-Bremse, Defense-in-depth neben Cloudflare):
# RATE_LIMIT_MAX=600          # Requests pro Fenster und IP (0 = aus)
# RATE_LIMIT_WINDOW_MS=60000  # Fensterlänge in ms
