N8N_BASE_URL=http://127.0.0.1:5678
N8N_API_KEY=deinen_n8n_api_key_hier_einfuegen
DASHBOARD_ADMIN_LOGIN=patrick@example.com
# Partner: alles sehen (betrieb.lesen + finanzen.lesen), nichts schreiben.
# Komma-getrennt für mehrere Kollegen.
# DASHBOARD_PARTNER_LOGIN=kollege@example.com
DASHBOARD_AUDIT_LOG=dashboard/logs/guest-access.jsonl
# Optional: Rechnungs-Upload direkt an einen festen n8n-Webhook posten (z. B. Mini-n8n),
# unabhaengig von N8N_BASE_URL. Der Webhook legt die Datei im Drive-Ordner Rechnungseingang ab.
# INVOICE_UPLOAD_WEBHOOK_URL=https://hp-mini-server.tail573a13.ts.net/webhook/wf1-rechnung-upload
# Vollabgleich Slotbelegung + Fuellstand aus Nayax: Webhook des Mini-WF "Nayax-Abgleich".
# mode=preview liefert die Nayax-machineProducts (read-only), mode=apply schreibt ueber WF-PGW.
# Pflicht fuer den "Aus Nayax abgleichen"-Knopf im v3-Dashboard (/slots).
# NAYAX_ABGLEICH_WEBHOOK_URL=http://n8n:5678/webhook/nayax-abgleich

# ─────────────────────────────────────────────────────────────────────────────
# Stufe 6 — Worker-Dienst (n8n-Ablösung). Diese Werte gehören in .env.local
# (NIEMALS ins Git). Der Worker (dashboard/worker.js) liest sie beim Start.
# ─────────────────────────────────────────────────────────────────────────────
# DB: App-Verbindung (Rolle automatenlager_app, RLS) für die Jobs durch die Tür;
# Infra-Verbindung (BYPASSRLS) für Registry/MatView/Telemetrie. Format wie server.js.
# DASHBOARD_V2_PG_URL=<App-PG-Verbindung, RLS>
# DASHBOARD_V2_APP_PG_URL=<optional separat; sonst = DASHBOARD_V2_PG_URL>

# E-Mail (Mailer-Modul, Resend — seit Slice 1 live). Für WF5-Digest + WF-Val/Monitor/Proposals.
# RESEND_API_KEY=<resend-key>
# MAIL_FROM=onboarding@resend.dev
# ALERT_EMAIL_DEFAULT=betreiber@example.com

# Anthropic (Slice 2): WF-Claude-Proposals (Vorentscheidung) + WF9 Pickliste-OCR.
# Modelle hartkodiert (claude-haiku-4-5-20251001). Ohne Key laufen die Jobs, rufen
# Claude aber NICHT ("Anthropic: disabled" im Worker-Log).
# ANTHROPIC_API_KEY=<anthropic-key>

# WF9 Pickliste (Slice 2): Google-Drive-Client (PDF-Ordner) ist eine OAuth-Abhängigkeit;
# ohne Client ist der WF9-Worker-Job "disabled". Beim Bau des Drive-Clients hier den
# Ziel-Mandanten setzen (Drive-Ordner → Mandant). Deploy-spezifisch.
# WF9_TENANT_ID=t_faltrix            # oder NAYAX_TENANT_ID
# GOOGLE_DRIVE_CLIENT_ID=<oauth-client-id>
# GOOGLE_DRIVE_CLIENT_SECRET=<oauth-client-secret>
# GOOGLE_DRIVE_REFRESH_TOKEN=<oauth-refresh-token>   # aus der n8n googleDriveOAuth2Api-Credential
# GOOGLE_DRIVE_PICKLIST_FOLDER_ID=1Djrp-44NtazCB3pa-07S-uK769gJ2ZcS   # Quell-Ordner (Picklisten)
# GOOGLE_DRIVE_PROCESSED_FOLDER_ID=1mOMTE-vTAKFqOO5DW_q9UQ1Hgd7MHV38  # Ziel nach Verarbeitung

# Schedule-Overrides (sonst Defaults): WF-Claude-Proposals 04:30, WF5 07:00, WF9 alle 5 min.
# WORKER_PROPOSALS_AT=04:30
# WORKER_WF5_AT=07:00
# WORKER_WF9_MS=300000

# Slice 3 (#163): WF3 Nayax-Verkäufe + WF1 Rechnungseingang. DEFAULT Schattenbetrieb
# (rechnen + vergleichen, KEIN Schreiben). Cutover erst nach bewiesener Deckungsgleichheit:
# WF3_CUTOVER=1 / WF1_CUTOVER=1 (dann durch die Tür schreiben). NAYAX_TENANT_ID = Ziel-Mandant.
# WF3_CUTOVER=1
# WF1_CUTOVER=1
# WORKER_WF3_AT=01:00
# WORKER_WF1_MS=600000

# Cutover-Readiness-Wächter (#198, täglich 02:00): zählt deckungsgleiche Schattenläufe,
# mailt bei Erreichen der Schwelle UND eröffnet bei einem Diff ein GitHub-Issue (24/7),
# damit der Fix im Backlog auftaucht. Ohne GITHUB_TOKEN/REPO ist nur die Mail aktiv.
# CUTOVER_STREAK_THRESHOLD=7
# WORKER_CUTOVER_AT=02:00
# GITHUB_TOKEN=<token mit issues:write>
# GITHUB_REPO=PatrickM-git/automatenlager

# Sicherheits-/Anomalie-Monitor (#168, alle 30 min): Auth-Fail-Häufung (guest-access.jsonl),
# Break-Glass-Nutzung, error-Run-Spike (audit.workflow_runs), Backup-Fehler (warnings).
# Mailt an ALERT_EMAIL_DEFAULT. Schwellwerte/Fenster überschreibbar.
# WORKER_ANOMALY_MS=1800000
# ANOMALY_WINDOW_MIN=60
# ANOMALY_AUTHFAIL_MAX=10
# ANOMALY_ERRORRUN_MAX=5
