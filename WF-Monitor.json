      "id": "a1000000-0000-0000-0000-000000000009",
      "name": "Postgres - Last Backup OK At",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [-380, 420],
      "credentials": {
        "postgres": {
          "id": "Jept3990Uq8aN3Tr",
