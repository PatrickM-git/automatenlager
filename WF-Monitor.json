    {
      "parameters": {
        "jsCode": "// Lädt wf-monitor-logic aus dem homelab-Repo\nconst path = require('path');\nconst { buildMonitoringReport } = require(path.join('/mnt/c/Users/patri/Documents/homelab/infra/scripts/wf-monitor-logic'));\n\n// Docker-ps-Output parsen\nconst dockerOutput = $('Execute Command - docker ps').first().json.stdout || '';\nconst allExpected = ['homelab-n8n', 'homelab-postgres', 'homelab-ollama', 'homelab-open-webui', 'homelab-dashboard'];\nconst containers = allExpected.map(name => ({\n  name,\n  up: dockerOutput.includes(name) && dockerOutput.split('\\n').some(line => line.includes(name) && line.toLowerCase().includes('up')),\n}));\n\n// PG-Heartbeat\nconst pgItems = $('Postgres - Heartbeat').all();\nconst postgresReachable = pgItems.length > 0 && pgItems[0].json.heartbeat === 1;\n\n// n8n-Errors seit der letzten Stunde filtern\nconst errorsRaw = $('HTTP Request - n8n Recent Errors').first().json;\nconst executions = (errorsRaw.data || []);\nconst oneHourAgo = new Date(Date.now() - 3600000).toISOString();\nconst workflowErrors = executions\n  .filter(e => e.startedAt >= oneHourAgo)\n  .map(e => ({\n    workflowId: e.workflowData?.id,\n    workflowName: e.workflowData?.name || 'unknown',\n    errorAt: e.startedAt,\n  }));\n\n// Schedule-Lücken\nconst wf5Items = $('HTTP Request - WF5 Last Success').first().json;\nconst wf8Items = $('HTTP Request - WF8 Last Success').first().json;\nconst scheduleLastSuccess = {\n  wf5: (wf5Items.data || [])[0]?.startedAt || null,\n  wf8: (wf8Items.data || [])[0]?.startedAt || null,\n};\n\n// Disk frei\nconst diskOutput = $('Execute Command - Disk Free GB').first().json.stdout || '100';\nconst diskFreeGb = parseFloat(diskOutput.trim()) || 100;\n\n// Letztes Backup OK\nconst backupItems = $('Postgres - Last Backup OK At').all();\nconst lastBackupOkAt = backupItems.length > 0 ? backupItems[0].json.last_backup_ok_at : null;\n\nconst report = buildMonitoringReport({\n  now: new Date().toISOString(),\n  containers,\n  postgresReachable,\n  workflowErrors,\n  scheduleLastSuccess,\n  diskFreeGb,\n  lastBackupOkAt,\n});\n\nreturn [{ json: report }];"
      },
      "id": "a1000000-0000-0000-0000-000000000010",
      "name": "Code - Build Monitoring Report",
